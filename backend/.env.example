PORT=3000
DATABASE_URL=postgresql://user:password@localhost:5432/beyond_classroom
JWT_SECRET=change-this-to-a-random-string-at-least-32-characters
JWT_EXPIRES_IN=7d
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=Beyond Classroom <noreply@beyondclassroom.id>
OTP_EXPIRY_MINUTES=10

# Sentry — get DSN from https://sentry.io → Project → Settings → Client Keys
SENTRY_DSN=

# Twilio Verify — get from console.twilio.com
# TWILIO_VERIFY_SID looks like VA...
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_VERIFY_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Midtrans — get from https://dashboard.sandbox.midtrans.com → Settings → Access Keys
# Use sandbox keys for development; switch to production keys for live
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxxxxxxxxxxxxxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxxxxxxxxxx
MIDTRANS_IS_PRODUCTION=false

# API.co.id — Indonesian school database API
# Get from https://api.co.id
# NOTE: Keep this secret and never commit to GitHub!
API_CO_ID_KEY=your-api-co-id-key-here
