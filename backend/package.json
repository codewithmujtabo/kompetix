{
  "name": "beyond-classroom-api",
  "version": "1.0.0",
  "description": "Beyond Classroom REST API - Express + PostgreSQL",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:migrate": "node-pg-migrate up --migrations-dir migrations",
    "db:migrate:down": "node-pg-migrate down --count 1 --migrations-dir migrations",
    "db:migrate:redo": "node-pg-migrate redo --migrations-dir migrations",
    "db:seed": "ts-node src/db/seed.ts",
    "db:seed:competitions": "ts-node src/db/seed-competitions-from-csv.ts",
    "db:create-admin": "ts-node src/db/create-admin.ts",
    "db:init": "psql $DATABASE_URL < src/db/schema.sql"
  },
  "dependencies": {
    "@sentry/node": "^10.47.0",
    "@types/multer": "^2.1.0",
    "@types/node-cron": "^3.0.11",
    "@types/pdfkit": "^0.17.6",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "csv-parse": "^6.2.1",
    "dotenv": "^16.4.0",
    "expo-server-sdk": "^6.1.0",
    "express": "^5.1.0",
    "express-rate-limit": "^8.3.2",
    "jsonwebtoken": "^9.0.2",
    "midtrans-client": "^1.4.3",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "node-fetch": "^2.7.0",
    "node-pg-migrate": "^8.0.4",
    "nodemailer": "^6.9.0",
    "pdfkit": "^0.18.0",
    "pg": "^8.13.0",
    "twilio": "^5.13.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.0",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/midtrans-client": "^1.4.0",
    "@types/node-fetch": "^2.6.13",
    "@types/nodemailer": "^6.4.0",
    "@types/pg": "^8.11.0",
    "nodemon": "^3.1.0",
    "ts-node": "^10.9.0",
    "typescript": "~5.9.2"
  }
}
