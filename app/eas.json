{
  "cli": {
    "version": ">= 14.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios":     { "simulator": true },
      "android": { "buildType": "apk" }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "ios":     { "simulator": false },
      "android": { "buildType": "apk" },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://staging-api.competzy.com/api"
      }
    },
    "production": {
      "channel": "production",
      "autoIncrement": true,
      "ios":     {},
      "android": { "buildType": "app-bundle" },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.competzy.com/api"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId":      "REPLACE_BEFORE_SUBMIT@example.com",
        "ascAppId":     "REPLACE_BEFORE_SUBMIT",
        "appleTeamId":  "REPLACE_BEFORE_SUBMIT"
      },
      "android": {
        "serviceAccountKeyPath": "../private/google-play-service-account.json",
        "track": "internal"
      }
    }
  }
}
